# AiBake Environment Configuration
# Copy this file to .env and update with your actual values

# Application
NODE_ENV=development
PORT=3000
APP_NAME=AiBake
APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://aibake_user:aibake_password@localhost:5432/aibake_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=20

# Redis Cache
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRATION=24h
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this-in-production
JWT_REFRESH_EXPIRATION=7d
BCRYPT_ROUNDS=12

# Cloud Storage (AWS S3 or Cloudflare R2)
STORAGE_PROVIDER=s3
STORAGE_BUCKET=aibake-uploads
STORAGE_REGION=ap-south-1
STORAGE_ACCESS_KEY_ID=your-access-key-id
STORAGE_SECRET_ACCESS_KEY=your-secret-access-key
STORAGE_ENDPOINT=
STORAGE_PUBLIC_URL=https://your-cdn-domain.com

# External Services
WHATSAPP_API_URL=https://api.whatsapp.com/v1
WHATSAPP_API_KEY=your-whatsapp-api-key
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

TRANSCRIPTION_SERVICE_URL=https://api.openai.com/v1/audio/transcriptions
TRANSCRIPTION_API_KEY=your-transcription-api-key

IMAGE_GEN_SERVICE_URL=https://api.stability.ai/v1
IMAGE_GEN_API_KEY=your-image-gen-api-key

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Frontend (for reference)
VITE_API_URL=http://localhost:3000/api/v1
VITE_APP_NAME=AiBake
