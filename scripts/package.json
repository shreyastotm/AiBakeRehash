{
  "name": "aibake-migrations",
  "version": "1.0.0",
  "description": "AiBake database migration scripts",
  "type": "module",
  "scripts": {
    "migrate": "node --loader ts-node/esm migrate.ts",
    "rollback": "node --loader ts-node/esm rollback.ts",
    "validate": "node --loader ts-node/esm validate.ts",
    "check": "node --loader ts-node/esm database-check.ts"
  },
  "dependencies": {
    "pg": "^8.11.3",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/pg": "^8.11.2",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
